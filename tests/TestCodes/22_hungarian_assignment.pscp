using System
using System.Collections.Generic

int n =
long[n][n] cost =
let INF = 4000000000000000000L
long[] u = new[n + 1]
long[] v = new[n + 1]
int[] p = new[n + 1]
int[] way = new[n + 1]

for i in 1..n {
    p[0] = i
    mut int j0 = 0
    long[] minv = new[n + 1]
    bool[] used = new[n + 1]
    for j in 0..n do minv[j] = INF
    while true {
        used[j0] = true
        let i0 = p[j0]
        mut long delta = INF
        mut int j1 = 0
        for j in 1..n {
            if used[j] then continue
            let cur = cost[i0 - 1][j - 1] - u[i0] - v[j]
            if cur < minv[j] {
                minv[j] = cur
                way[j] = j0
            }
            if minv[j] < delta {
                delta = minv[j]
                j1 = j
            }
        }
        for j in 0..n {
            if used[j] {
                u[p[j]] += delta
                v[j] -= delta
            } else {
                minv[j] -= delta
            }
        }
        j0 = j1
        if p[j0] == 0 then break
    }
    while true {
        let j1 = way[j0]
        p[j0] = p[j1]
        j0 = j1
        if j0 == 0 then break
    }
}

int[] assignment = new[n]
for j in 1..n do assignment[p[j] - 1] = j
+= -v[0]
stdout.join(' ', assignment)
+= ""
