using System.Collections.Generic

record struct Edge(int U, int V, long W)

void solve() {
    int n, m =
    Edge[m] edges;

    0..<m -> i {
        int u, v =
        long w =
        edges[i] = new Edge(u - 1, v - 1, w)
    }

    int[n] parent;
    int[n] size;
    0..<n -> i {
        parent[i] = i
        size[i] = 1
    }

    let sorted = edges.sortBy(e => e.W)
    var total = 0L
    var used = 0

    sorted -> e {
        if unite(parent, size, e.U, e.V) {
            total += e.W
            used += 1
        }
    }

    if used == n - 1 then += total else += "IMPOSSIBLE"
}

rec int find(int[] parent, int x) {
    if parent[x] == x then x
    else parent[x] := find(parent, parent[x])
}

bool unite(int[] parent, int[] size, int a, int b) {
    var ra = find(parent, a)
    var rb = find(parent, b)
    if ra == rb then false
    else {
        if size[ra] < size[rb] {
            let tmp = ra
            ra = rb
            rb = tmp
        }
        parent[rb] = ra
        size[ra] += size[rb]
        true
    }
}

solve()
